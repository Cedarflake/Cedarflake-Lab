{
  "name": "cedarflake-lab",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "check": "pnpm -r --if-present check",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "pnpm -r --if-present format",
    "format:check": "pnpm -r --if-present format:check",
    "dev:copilot-task": "pnpm --filter tasks-waitlist-preview dev",
    "dev:focus-orb": "pnpm --filter @igcrystal/focus-orb-demo dev",
    "dev:liminal-drift": "pnpm --filter liminal-drift dev",
    "dev:maimai-transition": "pnpm --filter maimai-transition dev",
    "dev:shika": "pnpm --filter shika dev",
    "email": "pnpm --filter personal_email email",
    "render:email": "pnpm --filter personal_email render:email",
    "check:focus-orb-package": "pnpm --filter @igcrystal/focus-orb build && pnpm --filter @igcrystal/focus-orb-demo exec tsc -p package-consumer/tsconfig.json --noEmit"
  }
}