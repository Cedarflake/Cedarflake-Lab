  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.4.3"
  }
